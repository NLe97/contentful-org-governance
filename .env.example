# --- Production env (set in Vercel project settings) -------------------------

# Customer's Contentful Personal Access Token. Should belong to a service-
# account org-admin user. Required for all cross-space CMA operations.
CONTENTFUL_MANAGEMENT_TOKEN=

# App Definition ID created via `pnpm setup:app-definition`.
APP_DEFINITION_ID=

# App Signing Secret printed by `pnpm setup:app-definition`. Used to verify
# signed requests from the Contentful iframe to /api/*.
APP_SIGNING_SECRET=

# Optional: App Private Key for App Identity (space-scoped CMA tokens).
# Only needed if you've also generated an App Private Key from the App
# Definition. Falls back to CONTENTFUL_MANAGEMENT_TOKEN if absent.
APP_PRIVATE_KEY=

# Random 32-byte hex string. Required to authenticate Vercel cron invocations.
CRON_SECRET=

# OPTIONAL but strongly recommended after first install. Pins the one space
# where the governance console lives. Every /api/* request whose
# consoleSpaceId param doesn't match this value is rejected with 403. Without
# it, a Space Admin who installs the app in a second space could trick the
# backend into writing state/audit entries in the wrong place. Set this AFTER
# you install the app in your chosen console space.
CONSOLE_SPACE_ID=

# HMAC root from which per-installation webhook secrets are derived. Required
# if you ever wire webhooks back on; not currently active (Contentful v11 has
# no org-level webhook API, see lib/secrets/derive-webhook-secret.ts).
GLOBAL_WEBHOOK_SECRET=

# --- Local / scripts only -----------------------------------------------------

# Legacy alias for CONTENTFUL_MANAGEMENT_TOKEN. Kept as a fallback so existing
# deployments don't break. Prefer CONTENTFUL_MANAGEMENT_TOKEN going forward.
CF_DEV_PAT=

# Used by scripts/ to point at a specific org/space. Not read by the runtime.
CF_ORG_ID=
CF_CONSOLE_SPACE_ID=
CF_TARGET_SPACE_ID=
CF_ACTOR_USER_ID=
