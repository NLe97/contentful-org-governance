{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm install --frozen-lockfile=false && cd app && pnpm install --frozen-lockfile=false && pnpm build",
  "outputDirectory": "app/dist",
  "functions": {
    "api/cron/reconcile.ts": { "maxDuration": 10 },
    "api/toggle-freeze.ts": { "maxDuration": 10 },
    "api/bootstrap.ts": { "maxDuration": 10 },
    "api/webhook.ts": { "maxDuration": 10 }
  },
  "crons": [
    { "path": "/api/cron/reconcile", "schedule": "0 6 * * *" }
  ]
}
